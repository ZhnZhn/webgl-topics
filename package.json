{
  "name": "webgl-topics",
  "version": "0.3.0",
  "description": "WebGL Topics",
  "keywords": [
    "WebGL",
    "React"
  ],
  "main": "index.js",
  "scripts": {
    "dev": "webpack serve --config webpack.dev.js",
    "dev:rspack": "rspack serve --config rspack.dev.js",
    "transpile": "babel ./src --out-dir ./js --source-maps --ignore ./**/__tests__",
    "transpile:all": "babel ./src --out-dir ./js --source-maps",
    "lint:one": "eslint -c eslint.config.js",
    "lint:biome": "npx @biomejs/biome lint ./src > _lint.txt 2>&1",
    "build:prod": "webpack --color --progress --config webpack.prod.js",
    "css:min": "node min-css"
  },
  "author": "Yevhenii Molodyi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZhnZhn/webgl-topics.git"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "gl-matrix": "^3.4.4",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@biomejs/biome": "^2.5.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@rspack/cli": "^2.0.8",
    "@rspack/core": "^2.0.8",
    "@rspack/dev-server": "^2.0.3",
    "@swc/helpers": "^0.5.23",
    "babel-loader": "^10.1.1",
    "clean-css": "^5.3.3",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "react-refresh": "^0.18.0",
    "terser-webpack-plugin": "^5.6.1",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "overrides": {
    "glob": "~13.0.6",
    "uuid": "~14.0.0",
    "js-yaml": "~4.2.0"
  }
}
